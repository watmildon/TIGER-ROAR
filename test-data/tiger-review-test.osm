<osm version='0.6' generator='TIGERReview Test Data'>

  <!--
    Test Data for TIGERReview JOSM Plugin

    This file contains test scenarios for all checks:
    1. Connected Road Check (name corroboration via connected roads)
    2. Address Check (name corroboration via nearby addr:street)
    3. Node Version Check (alignment verification via node versions)
    4. Surface Check (suggest surface from connected roads)

    Load this file in JOSM and run the validator to test.

    TESTING NOTE: Node versions are normally reset when loading OSM files.
    To enable testing, nodes use the __TEST_VERSION tag which the plugin
    reads instead of the actual OSM version. This allows testing version-based
    alignment checks with local test data.
  -->

  <!-- ============================================== -->
  <!-- SCENARIO 1: Name corroborated at BOTH ENDS    -->
  <!-- Three connected road segments sharing a name  -->
  <!-- Middle segment has tiger:reviewed=no          -->
  <!-- ============================================== -->

  <node id='-1' lat='40.0000' lon='-75.0000'>
    <tag k='__TEST_VERSION' v='2'/>
  </node>
  <node id='-2' lat='40.0005' lon='-75.0000'>
    <tag k='__TEST_VERSION' v='2'/>
  </node>
