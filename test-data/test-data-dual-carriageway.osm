    <tag k='highway' v='primary' />
    <tag k='name' v='Maple Highway' />
    <tag k='oneway' v='yes' />
    <tag k='tiger:reviewed' v='no' />
  </way>
  <way id='-200052' action='modify' visible='true'>
    <nd ref='-100053' />
    <nd ref='-100054' />
    <tag k='_test_id' v='DC6b' />
    <tag k='_test_note' v='tiger:reviewed=name — name is verified, corroborates DC6a' />
    <tag k='highway' v='primary' />
    <tag k='name' v='Maple Highway' />
    <tag k='oneway' v='yes' />
    <tag k='tiger:reviewed' v='name' />
  </way>

  <!-- === Scenario DC7: Motorway (implied oneway) → corroboration fires === -->
  <node id='-100061' action='modify' visible='true' lat='26.5760' lon='-81.6500' />
  <node id='-100062' action='modify' visible='true' lat='26.5760' lon='-81.6480' />
