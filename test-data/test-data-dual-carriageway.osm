    <tag k='_test_id' v='DC5b' />
    <tag k='_test_note' v='tiger:reviewed=alignment — does not prove name, should not corroborate DC5a' />
    <tag k='highway' v='secondary' />
    <tag k='name' v='Birch Drive' />
    <tag k='oneway' v='yes' />
    <tag k='tiger:reviewed' v='alignment' />
  </way>

  <!-- === Scenario DC6: tiger:reviewed=name on parallel → corroboration fires === -->
  <node id='-100051' action='modify' visible='true' lat='26.5750' lon='-81.6500' />
  <node id='-100052' action='modify' visible='true' lat='26.5750' lon='-81.6480' />
  <node id='-100053' action='modify' visible='true' lat='26.5752' lon='-81.6500' />
