<?xml version='1.0' encoding='UTF-8'?>
<osm version='0.6' generator='JOSM'>
  <!--
    Dual carriageway name corroboration test scenarios.
    All coordinates are in southwest Florida area (~26.57N, -81.65W).
    EastNorth distance at this latitude: ~1° lon ≈ 99,700m, ~1° lat ≈ 110,600m.
    So 0.0001° ≈ 10m laterally, 0.0002° ≈ 20m.
  -->

  <!-- === Scenario DC1: Parallel oneways, one reviewed → corroboration fires === -->
  <!-- Two parallel secondary roads ~20m apart, same name, both oneway.
       DC1a is tiger:reviewed=no, DC1b has no tiger:reviewed (i.e. reviewed).
       Expected: DC1a gets name corroborated via dual carriageway. -->
  <node id='-100001' action='modify' visible='true' lat='26.5700' lon='-81.6500' />
  <node id='-100002' action='modify' visible='true' lat='26.5700' lon='-81.6480' />
  <node id='-100003' action='modify' visible='true' lat='26.5702' lon='-81.6500' />
  <node id='-100004' action='modify' visible='true' lat='26.5702' lon='-81.6480' />
  <way id='-200001' action='modify' visible='true'>
    <nd ref='-100001' />
    <nd ref='-100002' />
    <tag k='_test_id' v='DC1a' />
    <tag k='_test_note' v='Parallel oneway, tiger:reviewed=no — should be corroborated by DC1b' />
    <tag k='highway' v='secondary' />
    <tag k='name' v='Main Boulevard' />
    <tag k='oneway' v='yes' />
    <tag k='tiger:reviewed' v='no' />
  </way>
  <way id='-200002' action='modify' visible='true'>
    <nd ref='-100004' />
    <nd ref='-100003' />
    <tag k='_test_id' v='DC1b' />
    <tag k='_test_note' v='Parallel oneway, reviewed (no tiger:reviewed tag) — corroborates DC1a' />
    <tag k='highway' v='secondary' />
    <tag k='name' v='Main Boulevard' />
    <tag k='oneway' v='yes' />
  </way>

  <!-- === Scenario DC2: Both unreviewed → no corroboration === -->
  <!-- Two parallel oneways, both tiger:reviewed=no. Should NOT corroborate. -->
  <node id='-100011' action='modify' visible='true' lat='26.5710' lon='-81.6500' />
  <node id='-100012' action='modify' visible='true' lat='26.5710' lon='-81.6480' />
  <node id='-100013' action='modify' visible='true' lat='26.5712' lon='-81.6500' />
  <node id='-100014' action='modify' visible='true' lat='26.5712' lon='-81.6480' />
  <way id='-200011' action='modify' visible='true'>
    <nd ref='-100011' />
    <nd ref='-100012' />
    <tag k='_test_id' v='DC2a' />
    <tag k='_test_note' v='Both unreviewed — should NOT be corroborated' />
    <tag k='highway' v='secondary' />
    <tag k='name' v='Oak Avenue' />
    <tag k='oneway' v='yes' />
    <tag k='tiger:reviewed' v='no' />
  </way>
  <way id='-200012' action='modify' visible='true'>
    <nd ref='-100013' />
    <nd ref='-100014' />
    <tag k='_test_id' v='DC2b' />
    <tag k='_test_note' v='Both unreviewed — should NOT be corroborated' />
    <tag k='highway' v='secondary' />
    <tag k='name' v='Oak Avenue' />
    <tag k='oneway' v='yes' />
    <tag k='tiger:reviewed' v='no' />
  </way>

  <!-- === Scenario DC3: Different names → no corroboration === -->
  <!-- Parallel oneways, one reviewed, but different names. -->
  <node id='-100021' action='modify' visible='true' lat='26.5720' lon='-81.6500' />
  <node id='-100022' action='modify' visible='true' lat='26.5720' lon='-81.6480' />
