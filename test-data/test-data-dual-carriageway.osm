    <tag k='name' v='Cedar Road' />
    <tag k='oneway' v='yes' />
  </way>

  <!-- === Scenario DC5: Alignment-only reviewed → no corroboration === -->
  <!-- Parallel oneway, but the corroborating road has tiger:reviewed=alignment.
       Alignment-only review does not prove the name is correct. -->
  <node id='-100041' action='modify' visible='true' lat='26.5740' lon='-81.6500' />
  <node id='-100042' action='modify' visible='true' lat='26.5740' lon='-81.6480' />
  <node id='-100043' action='modify' visible='true' lat='26.5742' lon='-81.6500' />
